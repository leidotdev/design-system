{
  "global": {
    "radius": {
      "$type": "borderRadius",
      "$value": "0.5rem",
      "$description": "Default border radius"
    },
    "radius-lg": {
      "$type": "borderRadius",
      "$value": "0.5rem",
      "$description": "Large border radius"
    },
    "radius-md": {
      "$type": "borderRadius",
      "$value": "calc(0.5rem - 2px)",
      "$description": "Medium border radius"
    },
    "radius-sm": {
      "$type": "borderRadius",
      "$value": "calc(0.5rem - 4px)",
      "$description": "Small border radius"
    }
  },
  "global/global": {
